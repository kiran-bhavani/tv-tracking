rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User Profiles & Watch Data ────────────────────────────────────────────
    // Only the authenticated owner can read or write their own document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Activity Feed ─────────────────────────────────────────────────────────
    // Authenticated users can create their own activity entries.
    // Anyone logged in can read the feed (for the community/feed page).
    // Only the author can delete their own entry.
    match /activityFeed/{entryId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow update: if false; // Activity entries are immutable
    }

    // ── Public Lists ──────────────────────────────────────────────────────────
    // Anyone can read a public list (for the share-link feature).
    // Only the authenticated author can create, update, or delete their list.
    match /public_lists/{listId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.authorId == request.auth.uid
                    && request.resource.data.authorId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.authorId == request.auth.uid;
    }

    // ── Episode Comments ──────────────────────────────────────────────────────
    // Anyone can read comments.
    // Only authenticated users can create a comment containing their own uid.
    // Only the original author can delete their comment.
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 2000;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow update: if false; // Comments are immutable once posted
    }

  }
}
